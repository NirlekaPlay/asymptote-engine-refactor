{
  "name": "asymptote-engine-refactor",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "shared": {
        "$path": "src/shared/ReplicatedStorage"
      }
    },

    "ServerScriptService": {
      "server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "$properties": {
        "HealthDisplayDistance": 0,
        "NameDisplayDistance": 0 
      },
      "StarterPlayerScripts": {
        "client": {
          "$path": "src/client/PlayerScripts"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "Lighting": {},
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      },
      "$path": "src/shared/SoundService"
    }
  }
}