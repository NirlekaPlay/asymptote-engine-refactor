{
  "name": "asymptote-engine-refactor",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "shared": {
        "$path": "src/shared"
      }
    },

    "ServerScriptService": {
      "server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "$properties": {
        "HealthDisplayDistance": 0,
        "NameDisplayDistance": 0 
      },
      "StarterPlayerScripts": {
        "client": {
          "$path": "src/client/PlayerScripts"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}